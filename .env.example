# ─── API ───────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173

# ─── Database ──────────────────────────────────────────
# Local dev (host): use localhost. Inside docker-compose: use "postgres".
DATABASE_URL=postgresql://accentrax:accentrax@localhost:5432/accentrax?schema=public
POSTGRES_USER=accentrax
POSTGRES_PASSWORD=accentrax
POSTGRES_DB=accentrax

# ─── Redis / Queue ─────────────────────────────────────
# Local dev (host): localhost. Inside docker-compose: "redis".
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Auth (Phase 1) ─────────────────────────────────────
# Generate real secrets for non-dev environments, e.g.: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-only-change-me-access-secret
JWT_REFRESH_SECRET=dev-only-change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_REFRESH_TTL_SECONDS=604800

# Seeded on first `prisma db seed` if no Super Admin exists yet.
ADMIN_EMAIL=admin@accentrax.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Super Admin

# ─── Storage ───────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage

# ─── Web ───────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api/v1
