# ─── API ───────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173

# ─── Database ──────────────────────────────────────────
# Local dev (host): use localhost. Inside docker-compose: use "postgres".
DATABASE_URL=postgresql://accentrax:accentrax@localhost:5432/accentrax?schema=public
POSTGRES_USER=accentrax
POSTGRES_PASSWORD=accentrax
POSTGRES_DB=accentrax

# ─── Redis / Queue ─────────────────────────────────────
# Local dev (host): localhost. Inside docker-compose: "redis".
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Auth (used from Phase 1) ──────────────────────────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Storage ───────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage

# ─── Web ───────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api/v1
